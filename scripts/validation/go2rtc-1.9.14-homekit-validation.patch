diff --git a/pkg/homekit/validation_audio.go b/pkg/homekit/validation_audio.go
new file mode 100644
index 0000000..25666b4
--- /dev/null
+++ b/pkg/homekit/validation_audio.go
@@ -0,0 +1,447 @@
+package homekit
+
+import (
+	"log"
+	"sort"
+	"sync"
+	"time"
+
+	"github.com/AlexxIT/go2rtc/pkg/core"
+	"github.com/AlexxIT/go2rtc/pkg/hap/camera"
+	"github.com/pion/rtp"
+)
+
+const (
+	validationAudioMaxPackets = 100
+	validationAudioWindow     = 2 * time.Second
+	validationAudioStallSlack = 150 * time.Millisecond
+)
+
+type validationAudioConfig struct {
+	codec             string
+	clockHz           uint32
+	channels          uint8
+	packetTimeMs      uint8
+	opus              bool
+	maxPackets        int
+	validationStarted time.Time
+	streamStartedAt   time.Time
+}
+
+type validationDistribution struct {
+	count  int
+	min    int64
+	median int64
+	p95    int64
+	max    int64
+}
+
+type validationAudioSummary struct {
+	codec        string
+	clockHz      uint32
+	channels     uint8
+	packetTimeMs uint8
+	totalMs      int64
+	sinceStartMs int64
+
+	packets              int
+	sequenceGapEvents    int
+	missing              int
+	duplicateOrBackwards int
+	timestampMismatches  int
+	tocParseFailures     int
+	stalls               int
+
+	rtpDeltas     validationDistribution
+	opusDurations validationDistribution
+	arrivalGaps   validationDistribution
+}
+
+type validationAudioAccumulator struct {
+	mu     sync.Mutex
+	config validationAudioConfig
+	done   bool
+
+	packets              int
+	sequenceGapEvents    int
+	missing              int
+	duplicateOrBackwards int
+	timestampMismatches  int
+	tocParseFailures     int
+	stalls               int
+
+	haveRTP           bool
+	previousSequence  uint16
+	previousTimestamp uint32
+	previousDuration  time.Duration
+
+	haveArrival             bool
+	previousArrival         time.Time
+	previousArrivalDuration time.Duration
+
+	rtpDeltas     []int64
+	opusDurations []int64
+	arrivalGaps   []int64
+}
+
+func newValidationAudioAccumulator(config validationAudioConfig) *validationAudioAccumulator {
+	if config.maxPackets <= 0 {
+		config.maxPackets = validationAudioMaxPackets
+	}
+	return &validationAudioAccumulator{config: config}
+}
+
+func validationAudioConfigFor(codec *camera.AudioCodecConfiguration) validationAudioConfig {
+	config := validationAudioConfig{
+		codec:      "UNKNOWN",
+		maxPackets: validationAudioMaxPackets,
+	}
+	if codec == nil {
+		return config
+	}
+	if int(codec.CodecType) < len(audioCodecs) {
+		config.codec = audioCodecs[codec.CodecType]
+		config.opus = config.codec == core.CodecOpus
+	}
+	if len(codec.CodecParams) == 0 {
+		return config
+	}
+
+	params := codec.CodecParams[0]
+	config.channels = params.Channels
+	if len(params.SampleRate) != 0 && int(params.SampleRate[0]) < len(audioSampleRates) {
+		config.clockHz = audioSampleRates[params.SampleRate[0]]
+	}
+	if len(params.RTPTime) != 0 {
+		config.packetTimeMs = params.RTPTime[0]
+	}
+	return config
+}
+
+func validationOpusFrameDuration(config byte) time.Duration {
+	switch config {
+	case 0, 4, 8, 12, 14, 18, 22, 26, 30:
+		return 10 * time.Millisecond
+	case 1, 5, 9, 13, 15, 19, 23, 27, 31:
+		return 20 * time.Millisecond
+	case 2, 6, 10:
+		return 40 * time.Millisecond
+	case 3, 7, 11:
+		return 60 * time.Millisecond
+	case 16, 20, 24, 28:
+		return 2500 * time.Microsecond
+	case 17, 21, 25, 29:
+		return 5 * time.Millisecond
+	}
+	return 0
+}
+
+func validationOpusPacketDuration(payload []byte) (time.Duration, bool) {
+	if len(payload) == 0 {
+		return 0, false
+	}
+
+	frameDuration := validationOpusFrameDuration(payload[0] >> 3)
+	if frameDuration == 0 {
+		return 0, false
+	}
+
+	var frames int
+	switch payload[0] & 0x03 {
+	case 0:
+		frames = 1
+		if len(payload)-1 > 1275 {
+			return 0, false
+		}
+	case 1:
+		frames = 2
+		frameBytes := len(payload) - 1
+		if frameBytes%2 != 0 || frameBytes/2 > 1275 {
+			return 0, false
+		}
+	case 2:
+		frames = 2
+		offset := 1
+		firstFrameBytes, ok := validationOpusFrameLength(payload, &offset)
+		if !ok || firstFrameBytes > 1275 {
+			return 0, false
+		}
+		secondFrameBytes := len(payload) - offset - firstFrameBytes
+		if secondFrameBytes < 0 || secondFrameBytes > 1275 {
+			return 0, false
+		}
+	case 3:
+		if len(payload) < 2 {
+			return 0, false
+		}
+		frameCode := payload[1]
+		frames = int(frameCode & 0x3f)
+		if frames == 0 {
+			return 0, false
+		}
+
+		offset := 2
+		paddingBytes := 0
+		if frameCode&0x40 != 0 {
+			for {
+				if offset >= len(payload) {
+					return 0, false
+				}
+				paddingCode := int(payload[offset])
+				offset++
+				if paddingCode == 255 {
+					paddingBytes += 254
+					continue
+				}
+				paddingBytes += paddingCode
+				break
+			}
+		}
+
+		dataEnd := len(payload) - paddingBytes
+		if dataEnd < offset {
+			return 0, false
+		}
+		if frameCode&0x80 == 0 {
+			frameBytes := dataEnd - offset
+			if frameBytes%frames != 0 || frameBytes/frames > 1275 {
+				return 0, false
+			}
+		} else {
+			signaledFrameBytes := 0
+			for i := 0; i < frames-1; i++ {
+				frameBytes, ok := validationOpusFrameLength(payload[:dataEnd], &offset)
+				if !ok || frameBytes > 1275 {
+					return 0, false
+				}
+				signaledFrameBytes += frameBytes
+			}
+			lastFrameBytes := dataEnd - offset - signaledFrameBytes
+			if lastFrameBytes < 0 || lastFrameBytes > 1275 {
+				return 0, false
+			}
+		}
+	}
+
+	duration := frameDuration * time.Duration(frames)
+	if frames == 0 || duration > 120*time.Millisecond {
+		return 0, false
+	}
+	return duration, true
+}
+
+func validationOpusFrameLength(payload []byte, offset *int) (int, bool) {
+	if *offset >= len(payload) {
+		return 0, false
+	}
+	first := int(payload[*offset])
+	*offset = *offset + 1
+	if first < 252 {
+		return first, true
+	}
+	if *offset >= len(payload) {
+		return 0, false
+	}
+	second := int(payload[*offset])
+	*offset = *offset + 1
+	frameLength := second*4 + first
+	if frameLength > 1275 {
+		return 0, false
+	}
+	return frameLength, true
+}
+
+func (a *validationAudioAccumulator) observe(packet *rtp.Packet, arrival time.Time) *validationAudioSummary {
+	a.mu.Lock()
+	defer a.mu.Unlock()
+
+	if a.done {
+		return nil
+	}
+
+	duration, durationOK := time.Duration(0), false
+	if a.config.opus {
+		duration, durationOK = validationOpusPacketDuration(packet.Payload)
+		if durationOK {
+			a.opusDurations = append(a.opusDurations, duration.Microseconds())
+		} else {
+			a.tocParseFailures++
+		}
+	}
+
+	if a.haveArrival {
+		if gap := arrival.Sub(a.previousArrival); gap >= 0 {
+			a.arrivalGaps = append(a.arrivalGaps, gap.Microseconds())
+
+			expected := a.previousArrivalDuration
+			if expected == 0 && a.config.packetTimeMs != 0 {
+				expected = time.Duration(a.config.packetTimeMs) * time.Millisecond
+			}
+			if expected != 0 && gap > expected+validationAudioStallSlack {
+				a.stalls++
+			}
+		}
+	}
+	a.haveArrival = true
+	a.previousArrival = arrival
+	if durationOK {
+		a.previousArrivalDuration = duration
+	} else {
+		a.previousArrivalDuration = 0
+	}
+
+	if !a.haveRTP {
+		a.haveRTP = true
+		a.previousSequence = packet.SequenceNumber
+		a.previousTimestamp = packet.Timestamp
+		if durationOK {
+			a.previousDuration = duration
+		}
+	} else {
+		step := uint16(packet.SequenceNumber - a.previousSequence)
+		switch {
+		case step == 0:
+			a.duplicateOrBackwards++
+		case step < 0x8000:
+			if step > 1 {
+				a.sequenceGapEvents++
+				a.missing += int(step) - 1
+			}
+
+			delta := packet.Timestamp - a.previousTimestamp
+			a.rtpDeltas = append(a.rtpDeltas, int64(delta))
+			if step == 1 && a.previousDuration != 0 && a.config.clockHz != 0 {
+				expected := uint32(
+					uint64(a.previousDuration) * uint64(a.config.clockHz) / uint64(time.Second),
+				)
+				if delta != expected {
+					a.timestampMismatches++
+				}
+			}
+
+			a.previousSequence = packet.SequenceNumber
+			a.previousTimestamp = packet.Timestamp
+			if durationOK {
+				a.previousDuration = duration
+			} else {
+				a.previousDuration = 0
+			}
+		default:
+			a.duplicateOrBackwards++
+		}
+	}
+
+	a.packets++
+	if a.packets >= a.config.maxPackets {
+		return a.finishLocked(arrival)
+	}
+	return nil
+}
+
+func (a *validationAudioAccumulator) finish(now time.Time) *validationAudioSummary {
+	a.mu.Lock()
+	defer a.mu.Unlock()
+	return a.finishLocked(now)
+}
+
+func (a *validationAudioAccumulator) finishLocked(now time.Time) *validationAudioSummary {
+	if a.done {
+		return nil
+	}
+	a.done = true
+
+	return &validationAudioSummary{
+		codec:                a.config.codec,
+		clockHz:              a.config.clockHz,
+		channels:             a.config.channels,
+		packetTimeMs:         a.config.packetTimeMs,
+		totalMs:              validationElapsedMilliseconds(a.config.validationStarted, now),
+		sinceStartMs:         validationElapsedMilliseconds(a.config.streamStartedAt, now),
+		packets:              a.packets,
+		sequenceGapEvents:    a.sequenceGapEvents,
+		missing:              a.missing,
+		duplicateOrBackwards: a.duplicateOrBackwards,
+		timestampMismatches:  a.timestampMismatches,
+		tocParseFailures:     a.tocParseFailures,
+		stalls:               a.stalls,
+		rtpDeltas:            validationDistributionFor(a.rtpDeltas),
+		opusDurations:        validationDistributionFor(a.opusDurations),
+		arrivalGaps:          validationDistributionFor(a.arrivalGaps),
+	}
+}
+
+func validationElapsedMilliseconds(started, now time.Time) int64 {
+	if started.IsZero() || now.Before(started) {
+		return 0
+	}
+	return now.Sub(started).Milliseconds()
+}
+
+func validationDistributionFor(values []int64) validationDistribution {
+	if len(values) == 0 {
+		return validationDistribution{}
+	}
+
+	sorted := append([]int64(nil), values...)
+	sort.Slice(sorted, func(i, j int) bool {
+		return sorted[i] < sorted[j]
+	})
+	percentile := func(p int) int64 {
+		index := (p*len(sorted)+99)/100 - 1
+		return sorted[index]
+	}
+
+	return validationDistribution{
+		count:  len(sorted),
+		min:    sorted[0],
+		median: percentile(50),
+		p95:    percentile(95),
+		max:    sorted[len(sorted)-1],
+	}
+}
+
+func validationMilliseconds(microseconds int64) float64 {
+	return float64(microseconds) / 1000
+}
+
+func logValidationAudioSummary(summary *validationAudioSummary) {
+	log.Printf(
+		"HKVAL phase=audio_summary total_ms=%d since_start_ms=%d "+
+			"codec=%s clock_hz=%d channels=%d packet_time_ms=%d "+
+			"packets=%d seq_gap_events=%d missing=%d duplicate_or_backwards=%d "+
+			"rtp_timestamp_mismatches=%d rtp_delta_samples=%d "+
+			"rtp_delta_min=%d rtp_delta_median=%d rtp_delta_p95=%d rtp_delta_max=%d "+
+			"opus_duration_samples=%d opus_duration_ms_min=%.3f opus_duration_ms_median=%.3f "+
+			"opus_duration_ms_p95=%.3f opus_duration_ms_max=%.3f toc_parse_failures=%d "+
+			"arrival_gap_samples=%d arrival_gap_ms_min=%.3f arrival_gap_ms_median=%.3f "+
+			"arrival_gap_ms_p95=%.3f arrival_gap_ms_max=%.3f stalls=%d",
+		summary.totalMs,
+		summary.sinceStartMs,
+		summary.codec,
+		summary.clockHz,
+		summary.channels,
+		summary.packetTimeMs,
+		summary.packets,
+		summary.sequenceGapEvents,
+		summary.missing,
+		summary.duplicateOrBackwards,
+		summary.timestampMismatches,
+		summary.rtpDeltas.count,
+		summary.rtpDeltas.min,
+		summary.rtpDeltas.median,
+		summary.rtpDeltas.p95,
+		summary.rtpDeltas.max,
+		summary.opusDurations.count,
+		validationMilliseconds(summary.opusDurations.min),
+		validationMilliseconds(summary.opusDurations.median),
+		validationMilliseconds(summary.opusDurations.p95),
+		validationMilliseconds(summary.opusDurations.max),
+		summary.tocParseFailures,
+		summary.arrivalGaps.count,
+		validationMilliseconds(summary.arrivalGaps.min),
+		validationMilliseconds(summary.arrivalGaps.median),
+		validationMilliseconds(summary.arrivalGaps.p95),
+		validationMilliseconds(summary.arrivalGaps.max),
+		summary.stalls,
+	)
+}
