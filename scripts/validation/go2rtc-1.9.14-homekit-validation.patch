@@ -0,0 +1,84 @@
+package homekit
+
+import "github.com/pion/rtp"
+
+type validationH264Milestone struct {
+	sps bool
+	pps bool
+
+	idrActive    bool
+	idrTimestamp uint32
+	idrBytes     int
+	idrPackets   int
+}
+
+type validationH264Result struct {
+	bytes     int
+	packets   int
+	timestamp uint32
+}
+
+func (m *validationH264Milestone) startIDR(timestamp uint32) {
+	m.idrActive = true
+	m.idrTimestamp = timestamp
+	m.idrBytes = 0
+	m.idrPackets = 0
+}
+
+func (m *validationH264Milestone) observeNAL(payload []byte, timestamp uint32) {
+	if len(payload) == 0 {
+		return
+	}
+
+	switch payload[0] & 0x1f {
+	case 5:
+		m.startIDR(timestamp)
+	case 7:
+		m.sps = true
+	case 8:
+		m.pps = true
+	case 24:
+		for offset := 1; offset+2 <= len(payload); {
+			length := int(payload[offset])<<8 | int(payload[offset+1])
+			offset += 2
+			if length == 0 || offset+length > len(payload) {
+				return
+			}
+			m.observeNAL(payload[offset:offset+length], timestamp)
+			offset += length
+		}
+	case 28:
+		if len(payload) >= 2 && payload[1]&0x80 != 0 && payload[1]&0x1f == 5 {
+			m.startIDR(timestamp)
+		}
+	}
+}
+
+func (m *validationH264Milestone) observe(packet *rtp.Packet) *validationH264Result {
+	if m.idrActive && packet.Timestamp != m.idrTimestamp {
+		m.idrActive = false
+	}
+
+	m.observeNAL(packet.Payload, packet.Timestamp)
+
+	if !m.idrActive || packet.Timestamp != m.idrTimestamp {
+		return nil
+	}
+
+	m.idrBytes += len(packet.Payload)
+	m.idrPackets++
+	if !packet.Marker {
+		return nil
+	}
+
+	result := &validationH264Result{
+		bytes:     m.idrBytes,
+		packets:   m.idrPackets,
+		timestamp: m.idrTimestamp,
+	}
+	m.idrActive = false
+	if !m.sps || !m.pps {
+		return nil
+	}
+	return result
+}
