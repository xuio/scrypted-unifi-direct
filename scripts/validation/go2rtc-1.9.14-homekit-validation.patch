@@ -0,0 +1,38 @@
+package homekit
+
+import (
+	"testing"
+
+	"github.com/pion/rtp"
+	"github.com/stretchr/testify/require"
+)
+
+func TestValidationH264Milestone(t *testing.T) {
+	var milestone validationH264Milestone
+
+	require.Nil(t, milestone.observe(&rtp.Packet{
+		Header:  rtp.Header{Timestamp: 100, Marker: true},
+		Payload: []byte{0x67, 0x64, 0x00, 0x33},
+	}))
+	require.Nil(t, milestone.observe(&rtp.Packet{
+		Header:  rtp.Header{Timestamp: 200, Marker: true},
+		Payload: []byte{0x68, 0xee, 0x3c, 0x80},
+	}))
+	require.Nil(t, milestone.observe(&rtp.Packet{
+		Header:  rtp.Header{Timestamp: 300},
+		Payload: []byte{0x7c, 0x85, 0xaa},
+	}))
+	require.Nil(t, milestone.observe(&rtp.Packet{
+		Header:  rtp.Header{Timestamp: 300},
+		Payload: []byte{0x7c, 0x05, 0xbb},
+	}))
+	result := milestone.observe(&rtp.Packet{
+		Header:  rtp.Header{Timestamp: 300, Marker: true},
+		Payload: []byte{0x7c, 0x45, 0xcc},
+	})
+
+	require.NotNil(t, result)
+	require.Equal(t, uint32(300), result.timestamp)
+	require.Equal(t, 9, result.bytes)
+	require.Equal(t, 3, result.packets)
+}
