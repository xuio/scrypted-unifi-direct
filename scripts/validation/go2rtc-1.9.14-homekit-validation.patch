new file mode 100644
index 0000000..e1faa3f
--- /dev/null
+++ b/pkg/homekit/validation_audio_test.go
@@ -0,0 +1,147 @@
+package homekit
+
+import (
+	"testing"
+	"time"
+
+	"github.com/AlexxIT/go2rtc/pkg/hap/camera"
+	"github.com/pion/rtp"
+	"github.com/stretchr/testify/require"
+)
+
+func TestValidationAudioConfigFor(t *testing.T) {
+	config := validationAudioConfigFor(&camera.AudioCodecConfiguration{
+		CodecType: camera.AudioCodecTypeOpus,
+		CodecParams: []camera.AudioCodecParameters{{
+			Channels:   1,
+			SampleRate: []byte{camera.AudioCodecSampleRate16Khz},
+			RTPTime:    []uint8{20},
+		}},
+	})
+
+	require.Equal(t, "OPUS", config.codec)
+	require.Equal(t, uint32(16000), config.clockHz)
+	require.Equal(t, uint8(1), config.channels)
+	require.Equal(t, uint8(20), config.packetTimeMs)
+	require.True(t, config.opus)
+	require.Equal(t, validationAudioMaxPackets, config.maxPackets)
+}
+
+func TestValidationOpusPacketDuration(t *testing.T) {
+	tests := []struct {
+		name     string
+		payload  []byte
+		duration time.Duration
+		ok       bool
+	}{
+		{name: "single 10ms", payload: []byte{0 << 3}, duration: 10 * time.Millisecond, ok: true},
+		{name: "two 20ms CBR", payload: []byte{1<<3 | 1, 1, 2}, duration: 40 * time.Millisecond, ok: true},
+		{name: "two 40ms VBR", payload: []byte{2<<3 | 2, 1, 1, 2}, duration: 80 * time.Millisecond, ok: true},
+		{name: "three 20ms", payload: []byte{31<<3 | 3, 3}, duration: 60 * time.Millisecond, ok: true},
+		{name: "forty eight 2.5ms", payload: []byte{16<<3 | 3, 48}, duration: 120 * time.Millisecond, ok: true},
+		{name: "code 1 odd payload", payload: []byte{1<<3 | 1, 1}},
+		{name: "code 2 missing length", payload: []byte{2<<3 | 2}},
+		{name: "code 2 truncated two byte length", payload: []byte{2<<3 | 2, 252}},
+		{name: "code 2 length exceeds data", payload: []byte{2<<3 | 2, 2, 1}},
+		{name: "empty", payload: nil},
+		{name: "missing code 3 count", payload: []byte{31<<3 | 3}},
+		{name: "zero frames", payload: []byte{31<<3 | 3, 0}},
+		{name: "over 120ms", payload: []byte{3<<3 | 3, 3}},
+		{name: "code 3 CBR uneven frames", payload: []byte{31<<3 | 3, 3, 1}},
+		{name: "code 3 VBR missing lengths", payload: []byte{31<<3 | 3, 0x80 | 3, 0}},
+		{name: "code 3 VBR length exceeds data", payload: []byte{31<<3 | 3, 0x80 | 2, 2, 1}},
+		{name: "code 3 truncated padding length", payload: []byte{31<<3 | 3, 0x40 | 1, 255}},
+		{name: "code 3 padding exceeds packet", payload: []byte{31<<3 | 3, 0x40 | 1, 2}},
+	}
+
+	for _, test := range tests {
+		t.Run(test.name, func(t *testing.T) {
+			duration, ok := validationOpusPacketDuration(test.payload)
+			require.Equal(t, test.ok, ok)
+			require.Equal(t, test.duration, duration)
+		})
+	}
+}
+
+func TestValidationOpusFrameLengthMaximum(t *testing.T) {
+	offset := 0
+	length, ok := validationOpusFrameLength([]byte{255, 255}, &offset)
+	require.True(t, ok)
+	require.Equal(t, 1275, length)
+	require.Equal(t, 2, offset)
+}
+
+func TestValidationAudioAccumulator(t *testing.T) {
+	accumulator := newValidationAudioAccumulator(validationAudioConfig{
+		codec:        "OPUS",
+		clockHz:      16000,
+		channels:     1,
+		packetTimeMs: 20,
+		opus:         true,
+		maxPackets:   5,
+	})
+	started := time.Unix(1, 0)
+	payload := []byte{1 << 3}
+	accumulator.config.validationStarted = started.Add(-50 * time.Millisecond)
+	accumulator.config.streamStartedAt = started.Add(-10 * time.Millisecond)
+
+	require.Nil(t, accumulator.observe(&rtp.Packet{
+		Header:  rtp.Header{SequenceNumber: 100, Timestamp: 1000},
+		Payload: payload,
+	}, started))
+	require.Nil(t, accumulator.observe(&rtp.Packet{
+		Header:  rtp.Header{SequenceNumber: 101, Timestamp: 1320},
+		Payload: payload,
+	}, started.Add(20*time.Millisecond)))
+	require.Nil(t, accumulator.observe(&rtp.Packet{
+		Header:  rtp.Header{SequenceNumber: 102, Timestamp: 1960},
+		Payload: payload,
+	}, started.Add(40*time.Millisecond)))
+	require.Nil(t, accumulator.observe(&rtp.Packet{
+		Header:  rtp.Header{SequenceNumber: 105, Timestamp: 2920},
+		Payload: payload,
+	}, started.Add(260*time.Millisecond)))
+	summary := accumulator.observe(&rtp.Packet{
+		Header:  rtp.Header{SequenceNumber: 105, Timestamp: 2920},
+		Payload: payload,
+	}, started.Add(280*time.Millisecond))
+
+	require.NotNil(t, summary)
+	require.Equal(t, int64(330), summary.totalMs)
+	require.Equal(t, int64(290), summary.sinceStartMs)
+	require.Equal(t, 5, summary.packets)
+	require.Equal(t, 1, summary.sequenceGapEvents)
+	require.Equal(t, 2, summary.missing)
+	require.Equal(t, 1, summary.duplicateOrBackwards)
+	require.Equal(t, 1, summary.timestampMismatches)
+	require.Equal(t, 0, summary.tocParseFailures)
+	require.Equal(t, 1, summary.stalls)
+	require.Equal(t, validationDistribution{
+		count: 3, min: 320, median: 640, p95: 960, max: 960,
+	}, summary.rtpDeltas)
+	require.Equal(t, validationDistribution{
+		count: 5, min: 20000, median: 20000, p95: 20000, max: 20000,
+	}, summary.opusDurations)
+	require.Equal(t, validationDistribution{
+		count: 4, min: 20000, median: 20000, p95: 220000, max: 220000,
+	}, summary.arrivalGaps)
+	require.Nil(t, accumulator.finish(started.Add(time.Second)))
+}
+
+func TestValidationAudioAccumulatorTimeoutSummary(t *testing.T) {
+	accumulator := newValidationAudioAccumulator(validationAudioConfig{
+		codec:        "OPUS",
+		clockHz:      16000,
+		channels:     1,
+		packetTimeMs: 20,
+		opus:         true,
+	})
+
+	summary := accumulator.finish(time.Unix(2, 0))
+	require.NotNil(t, summary)
+	require.Zero(t, summary.packets)
+	require.Zero(t, summary.rtpDeltas.count)
+	require.Zero(t, summary.opusDurations.count)
+	require.Zero(t, summary.arrivalGaps.count)
+	require.Nil(t, accumulator.finish(time.Unix(3, 0)))
+}
