{
  "name": "@scrypted/unifi-direct",
  "version": "0.1.0",
  "description": "Connect Scrypted directly to UniFi Protect cameras with no NVR/Console — live video, snapshots, audio, on-camera detections, zones, and full camera settings.",
  "author": "moritz",
  "license": "Unlicense",
  "keywords": [
    "scrypted",
    "scrypted-plugin",
    "unifi",
    "unifi-protect",
    "ubiquiti",
    "camera",
    "homekit",
    "rtsp"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "scrypted-setup-project": "scrypted-setup-project",
    "prescrypted-setup-project": "scrypted-package-json",
    "build": "scrypted-webpack",
    "prepack": "NODE_ENV=production scrypted-webpack",
    "prepublishOnly": "NODE_ENV=production scrypted-webpack",
    "prescrypted-vscode-launch": "scrypted-webpack",
    "scrypted-vscode-launch": "scrypted-deploy-debug",
    "scrypted-deploy-debug": "scrypted-deploy-debug",
    "scrypted-debug": "scrypted-debug",
    "scrypted-deploy": "scrypted-deploy",
    "scrypted-readme": "scrypted-readme",
    "scrypted-package-json": "scrypted-package-json",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test build-test/test/*.test.js",
    "test:client-runners": "node scripts/browser-startup.js --self-test && node scripts/homekit-startup.js --self-test && node scripts/homekit-snapshot.js --self-test",
    "test:soak": "python3 scripts/unifi-soak.py --self-test"
  },
  "main": "dist/main.nodejs.js",
  "dependencies": {
    "node-forge": "1.4.0"
  },
  "devDependencies": {
    "@scrypted/client": "^1.3.26",
    "@scrypted/sdk": "^0.5.59",
    "@types/node": "^22.20.1",
    "terser-webpack-plugin": "^5.6.1",
    "typescript": "^5.9.3"
  },
  "scrypted": {
    "name": "UniFi Direct",
    "type": "DeviceProvider",
    "interfaces": [
      "DeviceProvider",
      "DeviceCreator",
      "Settings"
    ],
    "pluginDependencies": [
      "@scrypted/prebuffer-mixin"
    ]
  }
}
